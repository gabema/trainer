@page "/activity"
@page "/activity/{Id:int}"
@inject IActivityService ActivityService
@inject IActivityTypeService ActivityTypeService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>@(IsEditMode ? "Edit Activity" : "Add Activity")</PageTitle>

<div class="header-area">
    <h1 class="mb-0">@(IsEditMode ? "Edit Activity" : "Add Activity")</h1>
</div>

<div class="container mt-4">
    <EditForm Model="@activity" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />
        
        <div class="mb-3">
            <label class="form-label">Type</label>
            <div class="input-group">
                <InputSelect @bind-Value="ActivityTypeId" class="form-select">
                    <option value="0">Select an activity type...</option>
                    @foreach (var type in activityTypes)
                    {
                        <option value="@type.Id">@type.Name</option>
                    }
                </InputSelect>
                <button type="button" class="btn btn-outline-secondary" @onclick="HandleActivityTypeButtonClick">
                    @if (activity.ActivityTypeId == 0)
                    {
                        <span>+</span>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708l-3-3zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207l6.5-6.5zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.499.499 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11l.178-.178z"/>
                        </svg>
                    }
                </button>
            </div>
            <ValidationMessage For="@(() => activity.ActivityTypeId)" />
        </div>

        <div class="mb-3">
            <label class="form-label">When</label>
            <div class="row g-2">
                <div class="col-md-6">
                    <InputDate @bind-Value="activity.When" class="form-control" />
                </div>
                <div class="col-md-6">
                    <input type="time" class="form-control" 
                           value="@activity.When.ToString("HH:mm")" 
                           @onchange="@((ChangeEventArgs e) => UpdateTime(e.Value?.ToString() ?? ""))" />
                </div>
            </div>
            <ValidationMessage For="@(() => activity.When)" />
        </div>

        <div class="mb-3">
            <label class="form-label">Amount@(selectedActivityType?.Unit != null ? $" ({selectedActivityType.Unit})" : "")</label>
            <InputNumber @bind-Value="activity.Amount" class="form-control" min="0" step="1" />
            <ValidationMessage For="@(() => activity.Amount)" />
        </div>

        <div class="mb-3">
            <label class="form-label">Duration (seconds or M:SS)</label>
            <InputText @bind-Value="durationInput" class="form-control" placeholder="e.g., 5:30 or 20" />
            <div class="form-text">
                Enter duration as seconds (e.g., <code>20</code> for 20 seconds) or minutes and seconds (e.g., <code>5:30</code> for 5 minutes 30 seconds).
            </div>
            @if (!string.IsNullOrEmpty(durationError))
            {
                <div class="text-danger small">@durationError</div>
            }
        </div>

        <div class="mb-3">
            <label class="form-label">Notes</label>
            <InputTextArea @bind-Value="activity.Notes" class="form-control" rows="4" />
        </div>

        <div class="mb-3">
            <button type="submit" class="btn btn-primary">@(IsEditMode ? "Update" : "Add")</button>
            <button type="button" class="btn btn-secondary ms-2" @onclick="Cancel">Cancel</button>
        </div>
    </EditForm>
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private Activity activity = new() { When = DateTime.Now };
    private List<ActivityType> activityTypes = new();
    private ActivityType? selectedActivityType;
    private bool IsEditMode => Id > 0;
    private string durationInput = string.Empty;
    private string? durationError;

    private int ActivityTypeId
    {
        get => activity.ActivityTypeId;
        set
        {
            activity.ActivityTypeId = value;
            UpdateSelectedActivityType();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        activityTypes = await ActivityTypeService.GetAllAsync();
        
        if (IsEditMode)
        {
            var existingActivity = await ActivityService.GetByIdAsync(Id);
            if (existingActivity != null)
            {
                activity = existingActivity;
            }
        }
        else
        {
            // Check for duplicate parameter
            var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
            if (!string.IsNullOrEmpty(uri.Query))
            {
                var queryString = uri.Query.TrimStart('?');
                var queryParams = queryString.Split('&')
                    .Select(p => p.Split('='))
                    .Where(p => p.Length == 2)
                    .ToDictionary(p => Uri.UnescapeDataString(p[0]), p => Uri.UnescapeDataString(p[1]));
                
                if (queryParams.TryGetValue("duplicateFrom", out var duplicateFromValue) && 
                    int.TryParse(duplicateFromValue, out var duplicateFromId))
                {
                    var sourceActivity = await ActivityService.GetByIdAsync(duplicateFromId);
                    if (sourceActivity != null)
                    {
                        // Create a new activity with the same data but Id = 0
                        activity = new Activity
                        {
                            Id = 0,
                            ActivityTypeId = sourceActivity.ActivityTypeId,
                            When = DateTime.Now,
                            Amount = sourceActivity.Amount,
                            Notes = sourceActivity.Notes,
                            DurationSeconds = sourceActivity.DurationSeconds
                        };
                    }
                }
            }
        }
        
        durationInput = FormatDuration(activity.DurationSeconds);
        UpdateSelectedActivityType();
    }

    private void UpdateSelectedActivityType()
    {
        selectedActivityType = activityTypes.FirstOrDefault(t => t.Id == activity.ActivityTypeId);
        StateHasChanged();
    }

    private string GetNavigationPath(string path)
    {
        var baseUri = Navigation.BaseUri.TrimEnd('/');
        var normalizedPath = path.TrimStart('/');
        return $"{baseUri}/{normalizedPath}";
    }

    private async Task HandleSubmit()
    {
        if (!TryParseDurationInput(durationInput, out var durationSeconds, out var error))
        {
            durationError = error;
            return;
        }

        durationError = null;
        activity.DurationSeconds = durationSeconds;

        if (IsEditMode)
        {
            await ActivityService.UpdateAsync(activity);
        }
        else
        {
            await ActivityService.AddAsync(activity);
        }
        
        Navigation.NavigateTo(GetNavigationPath("/"));
    }

    private void Cancel()
    {
        Navigation.NavigateTo(GetNavigationPath("/"));
    }

    private void HandleActivityTypeButtonClick()
    {
        // Build return URL to come back to this activity form
        var returnUrl = IsEditMode 
            ? $"/activity/{Id}" 
            : "/activity";
        var encodedReturnUrl = Uri.EscapeDataString(returnUrl);
        
        if (activity.ActivityTypeId == 0)
        {
            // Create new activity type
            Navigation.NavigateTo(GetNavigationPath($"/activity-type?returnUrl={encodedReturnUrl}"));
        }
        else
        {
            // Edit existing activity type
            Navigation.NavigateTo(GetNavigationPath($"/activity-type/{activity.ActivityTypeId}?returnUrl={encodedReturnUrl}"));
        }
    }

    private void UpdateTime(string timeString)
    {
        if (TimeSpan.TryParse(timeString, out var time))
        {
            activity.When = activity.When.Date + time;
        }
    }

    private static string FormatDuration(int? durationSeconds)
    {
        if (!durationSeconds.HasValue || durationSeconds.Value <= 0)
        {
            return string.Empty;
        }

        var totalSeconds = durationSeconds.Value;
        var minutes = totalSeconds / 60;
        var seconds = totalSeconds % 60;
        if (minutes == 0)
        {
            // Seconds only, e.g., "20"
            return $"{seconds}";
        }

        // Minutes and seconds, e.g., "5:30" or "5:00"
        return $"{minutes}:{seconds:00}";
    }

    private static bool TryParseDurationInput(string? input, out int? durationSeconds, out string? error)
    {
        durationSeconds = null;
        error = null;

        if (string.IsNullOrWhiteSpace(input))
        {
            return true;
        }

        input = input.Trim();
        var parts = input.Split(':');

        if (parts.Length == 1)
        {
            // Seconds-only input, e.g., "20"
            if (!int.TryParse(parts[0], out var secondsOnly))
            {
                error = "Duration must be a number of seconds or in M:SS format.";
                return false;
            }

            if (secondsOnly < 0)
            {
                error = "Duration cannot be negative.";
                return false;
            }

            durationSeconds = secondsOnly;
            return true;
        }

        if (parts.Length != 2)
        {
            error = "Duration must be a number of seconds (e.g., 20) or in M:SS format (e.g., 5:30).";
            return false;
        }

        if (!int.TryParse(parts[0], out var minutes) || !int.TryParse(parts[1], out var seconds))
        {
            error = "Minutes and seconds must be numeric.";
            return false;
        }

        if (minutes < 0 || seconds < 0)
        {
            error = "Duration cannot be negative.";
            return false;
        }

        if (seconds >= 60)
        {
            error = "Seconds must be between 00 and 59.";
            return false;
        }

        if (minutes > 999)
        {
            error = "Minutes must be less than 1000.";
            return false;
        }

        durationSeconds = (minutes * 60) + seconds;
        return true;
    }
}

