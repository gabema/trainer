@inject NavigationManager Navigation
@implements IDisposable

<nav class="top-nav-bar">
    <div class="nav-tabs-container">
        <NavLink class="@GetNavTabClass("")" href="" Match="NavLinkMatch.All">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                <path d="M6.5 14.5v-3.505c0-.245.25-.495.5-.495h2c.25 0 .5.25.5.5v3.5a.5.5 0 0 0 .5.5h4a.5.5 0 0 0 .5-.5v-7a.5.5 0 0 0-.146-.354L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293L8.354 1.146a.5.5 0 0 0-.708 0l-6 6A.5.5 0 0 0 1.5 7.5v7a.5.5 0 0 0 .5.5h4a.5.5 0 0 0 .5-.5Z"/>
            </svg>
            <span>Home</span>
        </NavLink>
        <NavLink class="@GetNavTabClass("activities")" href="activities" Match="NavLinkMatch.Prefix">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M5 11.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5M3.854 2.146a.5.5 0 0 1 0 .708l-1.5 1.5a.5.5 0 0 1-.708 0l-.5-.5a.5.5 0 1 1 .708-.708L2 3.293l1.146-1.147a.5.5 0 0 1 .708 0m0 4a.5.5 0 0 1 0 .708l-1.5 1.5a.5.5 0 0 1-.708 0l-.5-.5a.5.5 0 1 1 .708-.708L2 7.293l1.146-1.147a.5.5 0 0 1 .708 0m0 4a.5.5 0 0 1 0 .708l-1.5 1.5a.5.5 0 0 1-.708 0l-.5-.5a.5.5 0 0 1 .708-.708l.146.147 1.146-1.147a.5.5 0 0 1 .708 0"/>
            </svg>
            <span>Activities</span>
        </NavLink>
        <NavLink class="@GetNavTabClass("calendar")" href="calendar" Match="NavLinkMatch.All">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5M1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4z"/>
            </svg>
            <span>Calendar</span>
        </NavLink>
    </div>
</nav>

@code {
    private string GetNavTabClass(string route)
    {
        var currentUri = Navigation.Uri;
        var baseUri = Navigation.BaseUri;
        var relativeUri = currentUri.Replace(baseUri, "").TrimStart('/').Split('?')[0].Split('#')[0];
        
        bool isActive = false;
        if (string.IsNullOrEmpty(route))
        {
            // Home route - exact match
            isActive = string.IsNullOrEmpty(relativeUri) || relativeUri == "";
        }
        else if (route == "activities")
        {
            // Activities - prefix match
            isActive = relativeUri.StartsWith("activities", StringComparison.OrdinalIgnoreCase);
        }
        else if (route == "calendar")
        {
            // Calendar - exact match
            isActive = relativeUri.Equals("calendar", StringComparison.OrdinalIgnoreCase);
        }
        
        return isActive ? "nav-tab active" : "nav-tab";
    }

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
