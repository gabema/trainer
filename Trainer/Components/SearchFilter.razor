<label class="form-label">Search</label>
<input type="text" class="form-control" value="@Value" @oninput="OnInput" placeholder="@Placeholder" />

@code {
    [Parameter]
    public string Value { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> ValueChanged { get; set; }

    [Parameter]
    public string Placeholder { get; set; } = "Search by activity type, notes, or amount...";

    private async Task OnInput(ChangeEventArgs e)
    {
        await ValueChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty);
    }
}
