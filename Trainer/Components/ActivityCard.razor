@inject NavigationManager Navigation
@inject IActivityTypeService ActivityTypeService
@inject IActivityService ActivityService
@inject IJSRuntime JSRuntime

<div class="card activity-card mb-3 position-relative" style="cursor: pointer;" @onclick="() => ToggleOverlay()">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">@GetActivityTypeName()</span>
        <span class="text-muted small">@DateTimeHelper.FormatWhenDateTime(Activity.When)</span>
    </div>
    <div class="card-body">
        <div class="mb-2">
            <strong>@GetAmountDisplay()</strong>
        </div>
        @if (!string.IsNullOrWhiteSpace(Activity.Notes))
        {
            <div class="activity-notes">@Activity.Notes</div>
        }
    </div>
    
    @if (showOverlay)
    {
        <div class="activity-card-overlay-backdrop" @onclick="() => CloseOverlay()" @onclick:stopPropagation="true"></div>
        <div class="activity-card-overlay" @onclick:stopPropagation="true">
            <div class="activity-card-overlay-actions">
                <button class="btn btn-primary activity-card-overlay-button" @onclick="() => HandleEdit()" title="Edit">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708l-3-3zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207l6.5-6.5zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.499.499 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11l.178-.178z"/>
                    </svg>
                    <span>Edit</span>
                </button>
                <button class="btn btn-secondary activity-card-overlay-button" @onclick="() => HandleDuplicate()" title="Duplicate">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1z"/>
                        <path d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0z"/>
                    </svg>
                    <span>Duplicate</span>
                </button>
                @if (!string.IsNullOrWhiteSpace(Activity.Notes))
                {
                    <button class="btn btn-info activity-card-overlay-button" @onclick="() => HandleGuided()" title="Guided">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
                            <path d="M5.255 5.786a.237.237 0 0 0 .241.247h.825c.138 0 .248-.113.266-.25.09-.656.54-1.134 1.342-1.134.686 0 1.314.343 1.314 1.168 0 .635-.374.927-.965 1.371-.673.489-1.206 1.06-1.168 1.987l.003.217a.25.25 0 0 0 .25.246h.811a.25.25 0 0 0 .25-.25v-.105c0-.718.273-.927 1.01-1.486.609-.463 1.244-.977 1.244-2.056 0-1.511-1.276-2.241-2.673-2.241-1.267 0-2.655.59-2.75 2.286m1.557 5.763c0 .533.425.927 1.01.927.609 0 1.028-.394 1.028-.927 0-.552-.42-.94-1.029-.94-.584 0-1.009.388-1.009.94"/>
                        </svg>
                        <span>Guided</span>
                    </button>
                }
                <button class="btn btn-danger activity-card-overlay-button" @onclick="() => HandleDelete()" title="Delete">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/>
                        <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/>
                    </svg>
                    <span>Delete</span>
                </button>
            </div>
        </div>
    }
    
    @if (showDeleteConfirmation)
    {
        <div class="activity-card-overlay-backdrop" @onclick="() => CancelDelete()" @onclick:stopPropagation="true"></div>
        <div class="activity-card-delete-confirmation" @onclick:stopPropagation="true">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Confirm Delete</h5>
                </div>
                <div class="card-body">
                    <p>Are you sure you want to delete this activity?</p>
                </div>
                <div class="card-footer d-flex justify-content-end gap-2">
                    <button class="btn btn-secondary" @onclick="() => CancelDelete()">Cancel</button>
                    <button class="btn btn-danger" @onclick="() => ConfirmDelete()">Delete</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public Activity Activity { get; set; } = null!;

    [Parameter]
    public List<ActivityType> ActivityTypes { get; set; } = new();

    [Parameter]
    public EventCallback OnActivityDeleted { get; set; }

    private bool showOverlay = false;
    private bool showDeleteConfirmation = false;

    private string GetActivityTypeName()
    {
        return ActivityTypes.FirstOrDefault(t => t.Id == Activity.ActivityTypeId)?.Name ?? "Unknown";
    }

    private string GetAmountDisplay()
    {
        var activityType = ActivityTypes.FirstOrDefault(t => t.Id == Activity.ActivityTypeId);
        var amountText = activityType?.Unit != null
            ? $"{Activity.Amount} {activityType.Unit}"
            : Activity.Amount.ToString();

        var durationText = FormatDuration(Activity.DurationSeconds);
        if (!string.IsNullOrEmpty(durationText))
        {
            return $"{amountText} for {durationText}";
        }

        return amountText;
    }

    private static string? FormatDuration(int? durationSeconds)
    {
        if (!durationSeconds.HasValue || durationSeconds.Value <= 0)
        {
            return null;
        }

        var totalSeconds = durationSeconds.Value;
        var minutes = totalSeconds / 60;
        var seconds = totalSeconds % 60;

        if (minutes == 0)
        {
            // Seconds only (e.g., "20s")
            return $"{seconds}s";
        }

        if (seconds == 0)
        {
            // Whole minutes only (e.g., "20m")
            return $"{minutes}m";
        }

        return $"{minutes:0}m {seconds:00}s";
    }

    private void ToggleOverlay()
    {
        if (!showDeleteConfirmation)
        {
            showOverlay = !showOverlay;
            StateHasChanged();
        }
    }

    private void CloseOverlay()
    {
        showOverlay = false;
        StateHasChanged();
    }

    private void HandleEdit()
    {
        var baseUri = Navigation.BaseUri.TrimEnd('/');
        var normalizedPath = $"/activity/{Activity.Id}".TrimStart('/');
        var fullPath = $"{baseUri}/{normalizedPath}";
        Navigation.NavigateTo(fullPath);
    }

    private void HandleDuplicate()
    {
        var baseUri = Navigation.BaseUri.TrimEnd('/');
        var normalizedPath = $"/activity?duplicateFrom={Activity.Id}".TrimStart('/');
        var fullPath = $"{baseUri}/{normalizedPath}";
        Navigation.NavigateTo(fullPath);
    }

    private async Task HandleGuided()
    {
        if (string.IsNullOrWhiteSpace(Activity.Notes))
        {
            return;
        }

        try
        {
            CloseOverlay();
            await JSRuntime.InvokeVoidAsync("notificationHelper.startGuidedNotification", Activity.Id, Activity.Notes ?? "");
        }
        catch (Exception ex)
        {
            // Handle error - could show a toast notification or alert
            // For now, we'll just log it
            Console.WriteLine($"Error starting guided notification: {ex.Message}");
        }
    }

    private void HandleDelete()
    {
        showOverlay = false;
        showDeleteConfirmation = true;
        StateHasChanged();
    }

    private void CancelDelete()
    {
        showDeleteConfirmation = false;
        StateHasChanged();
    }

    private async Task ConfirmDelete()
    {
        showDeleteConfirmation = false;
        var activityId = Activity.Id;
        await ActivityService.DeleteAsync(activityId);
        try
        {
            await JSRuntime.InvokeVoidAsync("notificationHelper.clearGuidedState", activityId);
        }
        catch
        {
            // Ignore if notification helper or IndexedDB unavailable
        }
        await OnActivityDeleted.InvokeAsync();
        StateHasChanged();
    }
}

